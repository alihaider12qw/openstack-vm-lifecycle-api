APP_NAME=OpenStack VM Lifecycle API
APP_VERSION=0.1.0
ENVIRONMENT=dev
LOG_LEVEL=INFO
USE_MOCK_OPENSTACK=true
ALLOWED_ORIGINS=

# Real OpenStack values (used when USE_MOCK_OPENSTACK=false)
OPENSTACK_AUTH_URL=https://openstack.example.com:5000/v3
OPENSTACK_USERNAME=api-user
OPENSTACK_PASSWORD=change-me
OPENSTACK_PROJECT_NAME=demo-project
OPENSTACK_USER_DOMAIN_NAME=Default
OPENSTACK_PROJECT_DOMAIN_NAME=Default
